<form class="hide-ui-form" autocomplete="off">
   <div class="hide-ui-hint">
      <i class="fas fa-eye-slash"></i>
      <span>Check the items you want to <strong>hide</strong> from players. Unchecked items will remain visible on their screens.</span>
   </div>
   <div class="hide-ui-options">

      {{!-- ── Navigation ─────────────────────────────────────────── --}}
      <section class="hide-ui-section">
         <h3 class="hide-ui-section-header">
            <i class="fas fa-map"></i> Navigation
         </h3>
         <div class="hide-ui-option hide-ui-option--master">
            <label for="hideNavigation-complete">Hide All Navigation</label>
            <input type="checkbox" id="hideNavigation-complete" name="hideNavigation.complete"
               {{checked settings.hideNavigation.complete}} />
         </div>
         <div class="hide-ui-suboptions">
            <div class="hide-ui-option">
               <label for="hideNavigation-navToggle">Navigation Toggle</label>
               <input type="checkbox" id="hideNavigation-navToggle" name="hideNavigation.navToggle"
                  {{checked settings.hideNavigation.navToggle}} />
            </div>
            <div class="hide-ui-option">
               <label for="hideNavigation-sceneList">Scene List</label>
               <input type="checkbox" id="hideNavigation-sceneList" name="hideNavigation.sceneList"
                  {{checked settings.hideNavigation.sceneList}} />
            </div>
            {{#if renderBossBarOption}}
            <div class="hide-ui-option">
               <label for="hideNavigation-bossBar">Boss Bar</label>
               <input type="checkbox" id="hideNavigation-bossBar" name="hideNavigation.bossBar"
                  {{checked settings.hideNavigation.bossBar}} />
            </div>
            {{/if}}
         </div>
      </section>

      {{!-- ── Controls ─────────────────────────────────────────────── --}}
      <div class="hide-ui-option hide-ui-option--standalone">
         <label for="hideControls">
            <i class="fas fa-tools" style="margin-right:0.3rem;opacity:0.6"></i>
            Hide Controls Panel
         </label>
         <input type="checkbox" id="hideControls" name="hideControls" {{checked settings.hideControls}} />
      </div>

      {{!-- ── Sidebar ───────────────────────────────────────────────── --}}
      <section class="hide-ui-section">
         <h3 class="hide-ui-section-header">
            <i class="fas fa-columns"></i> Sidebar
         </h3>
         <div class="hide-ui-option hide-ui-option--master">
            <label for="hideSideBar-complete">Hide Entire Sidebar</label>
            <input type="checkbox" id="hideSideBar-complete" name="hideSideBar.complete"
               {{checked settings.hideSideBar.complete}} />
         </div>
         <div class="hide-ui-suboptions">
            <div class="hide-ui-option">
               <label for="hideSideBar-chatLog"><i class="fa-solid fa-comments"></i> Chat Messages</label>
               <input type="checkbox" id="hideSideBar-chatLog" name="hideSideBar.chatLog"
                  {{checked settings.hideSideBar.chatLog}} />
            </div>
            <div class="hide-ui-suboptions hide-ui-suboptions--deep">
               <div class="hide-ui-option">
                  <label for="hideSideBar-chatInput">Chat Input</label>
                  <input type="checkbox" id="hideSideBar-chatInput" name="hideSideBar.chatInput"
                     {{checked settings.hideSideBar.chatInput}} />
               </div>
            </div>
            <div class="hide-ui-option">
               <label for="hideSideBar-combatTracker"><i class="fa-solid fa-swords"></i> Combat Encounters</label>
               <input type="checkbox" id="hideSideBar-combatTracker" name="hideSideBar.combatTracker"
                  {{checked settings.hideSideBar.combatTracker}} />
            </div>
            <div class="hide-ui-option">
               <label for="hideSideBar-scenesDirectory"><i class="fa-solid fa-map"></i> Scenes</label>
               <input type="checkbox" id="hideSideBar-scenesDirectory" name="hideSideBar.scenesDirectory"
                  {{checked settings.hideSideBar.scenesDirectory}} />
            </div>
            <div class="hide-ui-option">
               <label for="hideSideBar-placeables"><i class="fa-solid fa-puzzle-piece"></i> Placeables</label>
               <input type="checkbox" id="hideSideBar-placeables" name="hideSideBar.placeables"
                  {{checked settings.hideSideBar.placeables}} />
            </div>
            <div class="hide-ui-option">
               <label for="hideSideBar-actorsDirectory"><i class="fa-solid fa-user"></i> Actors</label>
               <input type="checkbox" id="hideSideBar-actorsDirectory" name="hideSideBar.actorsDirectory"
                  {{checked settings.hideSideBar.actorsDirectory}} />
            </div>
            <div class="hide-ui-option">
               <label for="hideSideBar-itemsDirectory"><i class="fa-solid fa-suitcase"></i> Items</label>
               <input type="checkbox" id="hideSideBar-itemsDirectory" name="hideSideBar.itemsDirectory"
                  {{checked settings.hideSideBar.itemsDirectory}} />
            </div>
            <div class="hide-ui-option">
               <label for="hideSideBar-journalEntries"><i class="fa-solid fa-book-open"></i> Journal</label>
               <input type="checkbox" id="hideSideBar-journalEntries" name="hideSideBar.journalEntries"
                  {{checked settings.hideSideBar.journalEntries}} />
            </div>
            <div class="hide-ui-option">
               <label for="hideSideBar-rollableTables"><i class="fa-solid fa-table-list"></i> Rollable Tables</label>
               <input type="checkbox" id="hideSideBar-rollableTables" name="hideSideBar.rollableTables"
                  {{checked settings.hideSideBar.rollableTables}} />
            </div>
            <div class="hide-ui-option">
               <label for="hideSideBar-cardStacks"><i class="fa-solid fa-cards"></i> Card Stacks</label>
               <input type="checkbox" id="hideSideBar-cardStacks" name="hideSideBar.cardStacks"
                  {{checked settings.hideSideBar.cardStacks}} />
            </div>
            <div class="hide-ui-option">
               <label for="hideSideBar-macros"><i class="fa-solid fa-code"></i> Macros</label>
               <input type="checkbox" id="hideSideBar-macros" name="hideSideBar.macros"
                  {{checked settings.hideSideBar.macros}} />
            </div>
            <div class="hide-ui-option">
               <label for="hideSideBar-audioPlaylists"><i class="fa-solid fa-music"></i> Playlists</label>
               <input type="checkbox" id="hideSideBar-audioPlaylists" name="hideSideBar.audioPlaylists"
                  {{checked settings.hideSideBar.audioPlaylists}} />
            </div>
            <div class="hide-ui-option">
               <label for="hideSideBar-compendiumPacks"><i class="fa-solid fa-book-atlas"></i> Compendium Packs</label>
               <input type="checkbox" id="hideSideBar-compendiumPacks" name="hideSideBar.compendiumPacks"
                  {{checked settings.hideSideBar.compendiumPacks}} />
            </div>
            <div class="hide-ui-option">
               <label for="hideSideBar-gameSettings"><i class="fa-solid fa-gears"></i> Settings</label>
               <input type="checkbox" id="hideSideBar-gameSettings" name="hideSideBar.gameSettings"
                  {{checked settings.hideSideBar.gameSettings}} />
            </div>
            <div class="hide-ui-suboptions hide-ui-suboptions--deep">
               <div class="hide-ui-option">
                  <label for="hideSideBar-settingsContent-gameSettings">Game Settings</label>
                  <input type="checkbox" id="hideSideBar-settingsContent-gameSettings"
                     name="hideSideBar.settingsContent.gameSettings"
                     {{checked settings.hideSideBar.settingsContent.gameSettings}} />
               </div>
               <div class="hide-ui-option">
                  <label for="hideSideBar-settingsContent-activeModules">Active Modules <small>(players only)</small></label>
                  <input type="checkbox" id="hideSideBar-settingsContent-activeModules"
                     name="hideSideBar.settingsContent.activeModules"
                     {{checked settings.hideSideBar.settingsContent.activeModules}} />
               </div>
               <div class="hide-ui-option">
                  <label for="hideSideBar-settingsContent-tours">Tour Management</label>
                  <input type="checkbox" id="hideSideBar-settingsContent-tours"
                     name="hideSideBar.settingsContent.tours"
                     {{checked settings.hideSideBar.settingsContent.tours}} />
               </div>
               <div class="hide-ui-option">
                  <label for="hideSideBar-settingsContent-help">Help &amp; Documentation</label>
                  <input type="checkbox" id="hideSideBar-settingsContent-help"
                     name="hideSideBar.settingsContent.help"
                     {{checked settings.hideSideBar.settingsContent.help}} />
               </div>
            </div>
            {{#if renderDiceSoNiceOption}}
            <div class="hide-ui-option">
               <label for="hideSideBar-diceSoNice"><i class="fa-solid fa-dice-d20"></i> Dice So Nice!</label>
               <input type="checkbox" id="hideSideBar-diceSoNice" name="hideSideBar.diceSoNice"
                  {{checked settings.hideSideBar.diceSoNice}} />
            </div>
            {{/if}}
         </div>
      </section>

      {{!-- ── Players & Interface ──────────────────────────────────── --}}
      <section class="hide-ui-section">
         <h3 class="hide-ui-section-header">
            <i class="fas fa-users"></i> Players &amp; Interface
         </h3>
         <div class="hide-ui-option">
            <label for="hidePlayers">Active Players List</label>
            <input type="checkbox" id="hidePlayers" name="hidePlayers" {{checked settings.hidePlayers}} />
         </div>
         <div class="hide-ui-option">
            <label for="hidePlayerConfig">Player Configuration Button</label>
            <input type="checkbox" id="hidePlayerConfig" name="hidePlayerConfig"
               {{checked settings.hidePlayerConfig}} />
         </div>
      </section>

      {{!-- ── Hotbar ────────────────────────────────────────────────── --}}
      <section class="hide-ui-section">
         <h3 class="hide-ui-section-header">
            <i class="fas fa-th"></i> Hotbar
         </h3>
         <div class="hide-ui-option">
            <label for="hideHotbar">Macro Hotbar</label>
            <input type="checkbox" id="hideHotbar" name="hideHotbar" {{checked settings.hideHotbar}} />
         </div>
      </section>

      {{!-- ── HUD ──────────────────────────────────────────────────── --}}
      <section class="hide-ui-section">
         <h3 class="hide-ui-section-header">
            <i class="fas fa-dot-circle"></i> HUD
         </h3>
         <div class="hide-ui-option">
            <label for="hideTokenHUD">Token HUD</label>
            <input type="checkbox" id="hideTokenHUD" name="hideTokenHUD" {{checked settings.hideTokenHUD}} />
         </div>
         {{#if renderTokenActionHudOption}}
         <div class="hide-ui-option">
            <label for="hideTokenActionHUD">Token Action HUD</label>
            <input type="checkbox" id="hideTokenActionHUD" name="hideTokenActionHUD"
               {{checked settings.hideTokenActionHUD}} />
         </div>
         {{/if}}
      </section>

   </div>

   <footer class="hide-ui-form-footer">
      <button type="button" data-action="toggleAll">
         <i class="fas fa-check-double"></i> Toggle All
      </button>
      <button type="submit">
         <i class="fas fa-save"></i> Save Changes
      </button>
   </footer>
</form>
